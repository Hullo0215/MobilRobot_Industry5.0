import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist
from sensor_msgs.msg import JointState

class WheelController(Node):
    def __init__(self):
        super().__init__('wheel_controller')

        self.subscription = self.create_subscription(
            Twist,
            '/cmd_vel',
            self.cmd_callback,
            10)

        self.publisher = self.create_publisher(
            JointState,
            '/joint_states',
            10)

        self.joint_names = [
            'B1_1_joint','B2_1_joint','B3_1_joint','B4_1_joint','B5_1_joint','B6_1_joint',
            'J1_1_joint','J2_1_joint','J3_1_joint','J4_1_joint','J5_1_joint','J6_1_joint'
        ]

        self.positions = [0.0]*12

    def cmd_callback(self, msg):
        linear = msg.linear.x
        angular = msg.angular.z

        left = linear - angular
        right = linear + angular

        for i in range(6):
            self.positions[i] += left * 0.1

        for i in range(6, 12):
            self.positions[i] += right * 0.1

        js = JointState()
        js.name = self.joint_names
        js.position = self.positions

        self.publisher.publish(js)


def main(args=None):
    rclpy.init(args=args)
    node = WheelController()
    rclpy.spin(node)
    rclpy.shutdown()

if __name__ == '__main__':
    main()
